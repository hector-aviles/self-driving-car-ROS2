  orientation -0.031859202267191425 -0.9341266972329474 0.3555169542336395 6.091904330959901
  position 0.3523780099540419 5.125401377076397 16.951166049490766
}

# -----------------------------------------------------------------
# Road layout — single StraightRoadSegment, 4 lanes
#
# Cross-section (y axis, looking forward along +x):
#
#  Lane 1 (left shoulder) | Lane 2 (left travel) | Lane 3 (right travel) | Lane 4 (right shoulder)
#       3.0 m             |       3.65 m          |        3.65 m         |        3.0 m
#                continuous|               dashed  |continuous
#
# Total width: 3.0 + 3.65 + 3.65 + 3.0 = 13.3 m
#
# Lane centres (measured from road centre y=0):
#   Lane 1 left shoulder  : y = +(3.65+3.65)/2 + 3.0/2  = +5.15 m  (not used by traffic)
#   Lane 2 left travel    : y = +3.65/2                  = +1.825 m
#   Lane 3 right travel   : y = -3.65/2                  = -1.825 m
#   Lane 4 right shoulder : y = -(3.65+3.65)/2 - 3.0/2  = -5.15 m  (not used by traffic)
#
# Note: Webots lane width must be uniform across the segment.
# To approximate shoulder (3.0m) + travel (3.65m) with a single
# uniform lane width we use 3.325m average, which gives a visually
# close result. For exact widths, use two superimposed roads (see
# comment at bottom of file).
# -----------------------------------------------------------------

StraightRoadSegment {
  translation 0 0 0
  width 13.3
  numberOfLanes 4
  numberOfForwardLanes 4
  lines [
    RoadLine {
      type "continuous"
      color 1 1 1
    }
    RoadLine {
      type "dashed"
      color 1 1 1
    }
    RoadLine {
      type "continuous"
      color 1 1 1
    }
  ]
  rightBarrier TRUE
  leftBarrier TRUE
  length 300
  startLine [
    ""
    ""
    ""
    ""
  ]
  roadBoundingObject TRUE
  rightBorderBoundingObject TRUE
  leftBorderBoundingObject TRUE
}

TexturedBackground {
}
TexturedBackgroundLight {
}

